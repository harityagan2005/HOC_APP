# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Local)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hoc_app
DB_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=24h

# OTP Configuration
OTP_EXPIRY=5
OTP_LENGTH=6
OTP_RESEND_COOLDOWN=30

# Twilio Configuration (Add when ready for production)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# App Configuration
APP_NAME=HOC_APP
APP_URL=http://localhost:5000
