# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Local - MSSQL)
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=
DB_NAME=hoc_app
DB_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=24h

# OTP Configuration
# No SMS gateway is wired up — OTP always resolves to this fixed code.
OTP_DEFAULT_CODE=000000
OTP_EXPIRY=5
OTP_LENGTH=6
OTP_RESEND_COOLDOWN=30

# Twilio Configuration (Add when ready for production)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email (SMTP) Configuration — used to auto-notify departments on report creation
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# App Configuration
APP_NAME=HOC_APP
APP_URL=http://localhost:5000
